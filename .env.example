# Free/freemium model providers. Fill only the providers you want to use.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=

# Source preparation gates. Network fetches stay explicit.
ALLOW_HF_FETCH=0
ALLOW_GITHUB_FETCH=0
ALLOW_DOCS_DOWNLOAD=0

# Local indexing/model gates.
ALLOW_INDEX_BUILD=1
ALLOW_MODEL_DOWNLOADS=0

# Query-time cloud chat. Set ALLOW_CLOUD_CHAT=0 to force offline extractive fallback.
ALLOW_CLOUD_CHAT=1
MAX_CLOUD_CHAT_CALLS=1
CLOUD_CHAT_PROVIDER_TIMEOUT_SECONDS=10
CLOUD_CHAT_TOTAL_TIMEOUT_SECONDS=30

# Evaluation/RAGAS cloud gates. These do not enable query-time cloud chat by themselves.
USE_GEMINI_FREE_RAGAS=0
ALLOW_CLOUD_FREE_TIER=0
MAX_GEMINI_CALLS=120
GEMINI_RAGAS_STRICT=0
